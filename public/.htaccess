# ==============================================================================
# .htaccess for Daisoubus.jp (SPA on Apache)
# Generated by Gemini on 2025-06-20
#
# Summary of Rules:
# 1. Force HTTPS (SSL)
# 2. Force non-www domain (redirect www to non-www)
# 3. Handle SPA routing (redirect all non-file requests to index.html)
# 4. Set browser caching policy (mod_expires)
# ==============================================================================

# 启用重写引擎
<IfModule mod_rewrite.c>
    RewriteEngine On

    # --------------------------------------------------------------------------
    # Rule 1: 强制所有访问都使用 HTTPS
    # --------------------------------------------------------------------------
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
    RewriteRule ^/?(.*) https://%{HTTP_HOST}/$1 [R=301,L]

    # --------------------------------------------------------------------------
    # Rule 2: 强制使用非 www 域名 (将 www.daisoubus.jp 跳转到 daisoubus.jp)
    # --------------------------------------------------------------------------
    RewriteCond %{HTTP_HOST} ^www\.daisoubus\.jp [NC]
    RewriteRule ^(.*)$ https://daisoubus.jp/$1 [R=301,L]

    # --------------------------------------------------------------------------
    # Rule 3: 处理单页应用 (SPA) 的前端路由
    # 这是解决刷新页面404问题的核心规则
    # --------------------------------------------------------------------------
    # 设置项目的基础路径 (因为是根目录，所以是 /)
    RewriteBase /

    # 如果请求的不是一个已存在的文件
    RewriteCond %{REQUEST_FILENAME} !-f
    # 并且请求的不是一个已存在的目录
    RewriteCond %{REQUEST_FILENAME} !-d
    # 那么将所有请求重写到 index.html，让前端路由处理
    RewriteRule . /index.html [L]
</IfModule>

# ------------------------------------------------------------------------------
# Rule 4: 设置浏览器缓存策略 (提升网站加载速度)
# 需要 mod_expires 模块 (Onamae服务器通常已启用)
# ------------------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    # 默认缓存1个月
    ExpiresDefault                              "access plus 1 month"

    # HTML 文件不缓存
    ExpiresByType text/html                     "access plus 0 seconds"

    # CSS 和 JS 缓存1个月 (因为Vite构建后文件名会带哈希)
    ExpiresByType text/css                      "access plus 1 month"
    ExpiresByType application/javascript        "access plus 1 month"

    # 媒体文件缓存1个月
    ExpiresByType image/gif                     "access plus 1 month"
    ExpiresByType image/jpeg                    "access plus 1 month"
    ExpiresByType image/png                     "access plus 1 month"
    ExpiresByType image/webp                    "access plus 1 month"
    ExpiresByType image/svg+xml                 "access plus 1 month"
    ExpiresByType image/x-icon                  "access plus 1 year"

    # 字体文件缓存1年
    ExpiresByType application/font-woff         "access plus 1 year"
    ExpiresByType application/font-woff2        "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
    ExpiresByType application/x-font-ttf        "access plus 1 year"
</IfModule>

# Gzip/Brotli 压缩未启用（根据您的要求）。